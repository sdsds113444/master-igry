# Скопируйте в .env.local и заполните значениями из Supabase:
#   Supabase → Project Settings → API → Project URL и Publishable key (sb_publishable_...).
#
# Без этих двух переменных приложение работает на демо-данных (mock.ts) и не падает.
# Префикс VITE_ обязателен — только такие переменные Vite отдаёт в браузер.
# service_role / secret-ключ сюда НИКОГДА не кладём — только publishable/anon.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
